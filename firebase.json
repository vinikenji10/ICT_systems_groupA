{
  "hosting": {
    "public": "sit-club-hub/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/clubs/*",
        "destination": "/clubs/placeholder/index.html"
      },
      {
        "source": "/dashboard/edit/*",
        "destination": "/dashboard/edit/placeholder/index.html"
      },
      {
        "source": "/dashboard/events/*",
        "destination": "/dashboard/events/placeholder/index.html"
      },
      {
        "source": "/dashboard/applications/*",
        "destination": "/dashboard/applications/placeholder/index.html"
      }
    ]
  },
  "functions": [
    {
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "venv",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "source": "functions",
      "runtime": "python313"
    }
  ],
  "firestore": {
    "database": "(default)",
    "location": "asia-northeast1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
